{
  "identifier": "default",
  "description": "Default capability for TinyFusion",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-title",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-open",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "tinyfusion-core",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "tinyfusion-core",
          "sidecar": true
        }
      ]
    }
  ]
}
